# Anthropic
ANTHROPIC_API_KEY=       # sk-ant-... from console.anthropic.com

# HubSpot
HUBSPOT_TOKEN=           # Private app token — see README for required scopes
HUBSPOT_PORTAL_ID=       # Your HubSpot portal ID (visible in any HubSpot URL)
HUBSPOT_LIST_ID=         # ID of company list to scan (omit to scan entire database)
HUBSPOT_TASK_QUEUE_ID=   # ID of the "Dedup Review" task queue — see README
HUBSPOT_TASK_OWNER_ID=   # HubSpot owner ID to assign tasks to (owner ID, not user ID)

# Behaviour
DEDUP_DRY_RUN=true               # true = log only, no HubSpot writes. Set false to create tasks.
DEDUP_LIVE_MERGE=false           # true = auto-merge high-confidence pairs. Keep false until calibrated.
MAX_AUTO_MERGES_PER_RUN=25       # Safety cap on auto-merges per run (only when DEDUP_LIVE_MERGE=true)
MAX_TASKS_PER_RUN=30             # Max review tasks created per nightly run
DEDUP_SCAN_LIMIT=                # Optional: cap companies scanned per run (e.g. 500 for testing)
DEDUP_CRON=0 2 * * *             # Cron schedule (default: 2am daily)
CRON_TZ=America/Los_Angeles      # Timezone for cron schedule

# Most hosts (Railway, Render, Fly) inject PORT automatically; defaults to 3000
